---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/base";

interface Props {
  posts: CollectionEntry<"posts">[];
}

const { posts } = Astro.props;

const grouped = posts.reduce<Record<string, CollectionEntry<"posts">[]>>((acc, post) => {
  const key = post.data.date.toISOString().slice(0, 10);
  if (!acc[key]) {
    acc[key] = [];
  }
  acc[key].push(post);
  return acc;
}, {});

const dates = Object.keys(grouped).sort((a, b) => b.localeCompare(a));
---

<style>
  .archive {
    display: grid;
    gap: 1.5rem;
  }

  .archive-day {
    display: grid;
    gap: 0.7rem;
    padding: 1.35rem;
    border-radius: var(--radius-panel);
    background: linear-gradient(180deg, #ffffff 0%, #fbfbfd 100%);
    border: 1px solid rgba(255, 255, 255, 0.88);
    box-shadow: var(--shadow);
  }

  .archive-day h3 {
    margin: 0;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-subtle);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .archive-link {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--border);
    border-radius: 24px;
    text-decoration: none;
    background: rgba(250, 250, 252, 0.86);
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .archive-link:hover {
    border-color: rgba(0, 113, 227, 0.18);
    transform: translateY(-1px);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.08);
  }

  .archive-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .archive-dot.morning {
    background: var(--accent);
  }

  .archive-dot.evening {
    background: var(--surface-dark-2);
  }

  .archive-title {
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .archive-meta {
    margin-left: auto;
    color: var(--text-subtle);
    font-size: 0.8rem;
  }

  @media (max-width: 720px) {
    .archive-link {
      align-items: start;
      flex-direction: column;
    }

    .archive-meta {
      margin-left: 0;
    }
  }
</style>

{
  dates.length === 0 ? (
    <p class="empty-state">No posts have been generated yet.</p>
  ) : (
    <div class="archive">
      {dates.map((dateKey) => (
        <section class="archive-day">
          <h3>
            {new Date(`${dateKey}T12:00:00Z`).toLocaleDateString("en-US", {
              weekday: "long",
              month: "long",
              day: "numeric",
              year: "numeric",
            })}
          </h3>
          {grouped[dateKey]
            .sort((a, b) => {
              if (a.data.type === b.data.type) {
                return 0;
              }
              return a.data.type === "morning" ? -1 : 1;
            })
            .map((post) => (
              <a class="archive-link" href={withBase(`/posts/${post.slug}/`)}>
                <span class={`archive-dot ${post.data.type}`}></span>
                <span class="archive-title">{post.data.title}</span>
                <span class="archive-meta">{post.data.story_count} stories</span>
              </a>
            ))}
        </section>
      ))}
    </div>
  )
}
