---
interface Props {
  title: string;
  date: Date;
  time: string;
  type: "morning" | "evening" | "colorado";
  story_count: number;
}

const { title, date, time, type, story_count } = Astro.props;

const displayDate = new Date(date);
displayDate.setUTCHours(12, 0, 0, 0);

const dateLabel = displayDate.toLocaleDateString("en-US", {
  weekday: "long",
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: "America/Denver",
});

const editionLabel =
  type === "morning" ? "Morning Edition"
  : type === "colorado" ? "Colorado Edition"
  : "Evening Edition";
---

<style>
  .post {
    display: grid;
    gap: 1.75rem;
    padding: clamp(1.6rem, 3vw, 3rem);
    border-radius: var(--radius-panel);
    background: linear-gradient(180deg, var(--panel-gradient-start) 0%, var(--panel-gradient-end) 100%);
    border: 1px solid var(--panel-border);
    box-shadow: var(--shadow);
  }

  .post-header {
    padding-bottom: 1.35rem;
    border-bottom: 1px solid var(--border);
  }

  .post-header h2 {
    margin: 0 0 1rem;
    font-size: clamp(2.3rem, 5vw, 4rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 1.05;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    color: var(--text-subtle);
    font-size: 0.9rem;
  }

  .post-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.34rem 0.72rem;
    border-radius: 999px;
    background: var(--toggle-icon-bg);
    color: var(--accent-link);
    font-weight: 600;
  }

  .post-body {
    color: var(--text);
    line-height: 1.7;
    font-size: 1.0625rem;
  }

  .post-body :global(p) {
    margin: 0 0 1rem;
    color: var(--text-muted);
  }

  .post-body :global(h2),
  .post-body :global(h3) {
    margin: 1.8rem 0 0.7rem;
    color: var(--text);
  }

  .post-body :global(a) {
    color: var(--accent-link);
  }
</style>

<article class="post">
  <header class="post-header">
    <h2>{title}</h2>
    <div class="post-meta">
      <span class="post-pill">{editionLabel}</span>
      <span>{dateLabel}</span>
      <span>{time} MT</span>
      <span>{story_count} stories</span>
    </div>
  </header>
  <div class="post-body">
    <slot />
  </div>
</article>
