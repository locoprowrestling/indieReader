---
import { withBase } from "../lib/base";

interface Props {
  active: "news" | "blog" | "archive";
}

const { active } = Astro.props;
---

<nav class="tabs" aria-label="Primary">
  <a href={withBase("/")} class={active === "news" ? "active" : undefined}>News</a>
  <a href={withBase("/blog/")} class={active === "blog" ? "active" : undefined}>Current Post</a>
  <a href={withBase("/archive/")} class={active === "archive" ? "active" : undefined}>Post Archive</a>
</nav>
