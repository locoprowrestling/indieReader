---
interface Story {
  id?: string;
  title: string;
  summary: string;
  url: string;
  source: string;
  published_at: string;
  platform: string;
}

interface Props {
  stories: Story[];
}

const { stories } = Astro.props;

function formatTime(iso: string) {
  return new Date(iso).toLocaleTimeString("en-US", {
    hour: "numeric",
    minute: "2-digit",
    timeZone: "America/Denver",
  });
}

function platformLabel(platform: string) {
  switch (platform) {
    case "rss":
      return "RSS";
    case "scrape":
      return "Scrape";
    case "twitter":
      return "Twitter";
    case "facebook":
      return "Facebook";
    case "instagram":
      return "Instagram";
    case "youtube":
      return "YouTube";
    default:
      return "Source";
  }
}
---

<style>
  .feed {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.15rem;
  }

  .story {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: var(--radius-card);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(247, 247, 250, 0.92)),
      var(--surface-solid);
    box-shadow: var(--shadow);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .story--featured {
    grid-column: 1 / -1;
    padding: clamp(1.7rem, 4vw, 2.6rem);
    background:
      radial-gradient(circle at top right, rgba(41, 151, 255, 0.28), transparent 28%),
      linear-gradient(180deg, #1d1d1f 0%, #272729 100%);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.06);
  }

  .story--featured .story-copy {
    max-width: 48rem;
  }

  .story:hover {
    transform: translateY(-2px);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.12);
  }

  .story-meta {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: var(--text-subtle);
    letter-spacing: -0.01em;
  }

  .story-chip {
    padding: 0.32rem 0.68rem;
    border-radius: 999px;
    background: var(--chip-bg);
    color: var(--text-muted);
    font-weight: 600;
  }

  .story--featured .story-chip {
    background: rgba(41, 151, 255, 0.18);
    color: #ffffff;
  }

  .story h3 {
    margin: 0;
    font-size: 1.45rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.12;
  }

  .story--featured h3 {
    font-size: clamp(2.1rem, 5vw, 3.35rem);
    max-width: 12ch;
  }

  .story h3 a {
    text-decoration: none;
  }

  .story h3 a:hover {
    color: var(--accent-link);
  }

  .story--featured h3 a:hover,
  .story--featured .story-source-link:hover {
    color: var(--accent-bright);
  }

  .story p {
    margin: 0;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .story--featured p,
  .story--featured .story-meta {
    color: rgba(255, 255, 255, 0.76);
  }

  .story-source-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--accent-link);
    font-size: 0.94rem;
    font-weight: 500;
    text-decoration: none;
  }

  .story-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 760px) {
    .feed {
      grid-template-columns: 1fr;
    }

    .story--featured {
      grid-column: auto;
    }
  }
</style>

{
  stories.length === 0 ? (
    <p class="empty-state">No stories fetched yet. Check back after the next crawl.</p>
  ) : (
    <div class="feed">
      {stories.map((story, index) => (
        <article class:list={["story", index === 0 && "story--featured"]}>
          <div class="story-meta">
            <span class="story-chip">{platformLabel(story.platform)}</span>
            <span>{story.source}</span>
            <span>{formatTime(story.published_at)} MT</span>
          </div>
          <div class="story-copy">
            <h3>
              <a href={story.url} target="_blank" rel="noreferrer">
                {story.title}
              </a>
            </h3>
            <p>{story.summary}</p>
          </div>
          <div class="story-footer">
            <a class="story-source-link" href={story.url} target="_blank" rel="noreferrer">
              Read source
            </a>
          </div>
        </article>
      ))}
    </div>
  )
}
