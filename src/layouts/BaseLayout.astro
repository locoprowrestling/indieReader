---
interface Props {
  title?: string;
}

const { title = "indieReader" } = Astro.props;
const homeUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Daily indie wrestling news and editorial coverage."
    />
    <title>{title} | indieReader</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f5f5f7;
        --bg-alt: #fafafc;
        --surface: rgba(255, 255, 255, 0.9);
        --surface-solid: #ffffff;
        --surface-dark: #1d1d1f;
        --surface-dark-2: #272729;
        --border: rgba(0, 0, 0, 0.08);
        --border-strong: rgba(0, 0, 0, 0.12);
        --text: #1d1d1f;
        --text-muted: rgba(0, 0, 0, 0.8);
        --text-subtle: rgba(0, 0, 0, 0.48);
        --accent: #0071e3;
        --accent-link: #0066cc;
        --accent-bright: #2997ff;
        --chip-bg: #fafafc;
        --chip-active: #ededf2;
        --shadow: 0 24px 60px rgba(0, 0, 0, 0.08);
        --radius-panel: 32px;
        --radius-card: 28px;
        --content-width: min(980px, calc(100vw - 1.5rem));
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
      }

      body {
        font-family:
          -apple-system,
          BlinkMacSystemFont,
          "SF Pro Display",
          "SF Pro Text",
          "Helvetica Neue",
          Arial,
          sans-serif;
        background:
          radial-gradient(circle at top center, rgba(41, 151, 255, 0.12), transparent 28%),
          linear-gradient(180deg, #ffffff 0%, #f5f5f7 26%, #fafafc 100%);
        color: var(--text);
        line-height: 1.47;
      }

      a {
        color: inherit;
      }

      .site-shell {
        padding: 0.9rem 0 4rem;
      }

      .site-header {
        width: var(--content-width);
        margin: 0 auto 1.5rem;
        padding: 0.65rem 0.85rem;
        border: 1px solid rgba(0, 0, 0, 0.06);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.72);
        box-shadow: 0 8px 26px rgba(0, 0, 0, 0.08);
        backdrop-filter: saturate(180%) blur(24px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        position: sticky;
        top: 0.75rem;
        z-index: 20;
      }

      .site-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        text-decoration: none;
      }

      .brand-mark {
        width: 2rem;
        height: 2rem;
        border-radius: 50%;
        display: grid;
        place-items: center;
        background: linear-gradient(180deg, #1d1d1f, #2a2a2d);
        color: #ffffff;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: -0.04em;
      }

      .brand-lockup {
        display: grid;
        gap: 0.05rem;
      }

      .brand-lockup strong {
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: -0.02em;
      }

      .brand-lockup span {
        font-size: 0.78rem;
        color: var(--text-subtle);
      }

      .site-note {
        margin: 0;
        color: var(--text-subtle);
        font-size: 0.82rem;
      }

      main {
        width: var(--content-width);
        margin: 0 auto;
        display: grid;
        gap: 1.4rem;
      }

      .site-footer {
        width: var(--content-width);
        margin: 1.5rem auto 0;
        padding: 1rem 1.25rem;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.68);
        border: 1px solid rgba(0, 0, 0, 0.06);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
        backdrop-filter: saturate(180%) blur(18px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.9rem;
        flex-wrap: wrap;
      }

      .site-footer-copy {
        margin: 0;
        color: var(--text-subtle);
        font-size: 0.82rem;
        line-height: 1.5;
      }

      .site-footer-link {
        color: var(--accent-link);
        font-weight: 600;
        text-decoration: none;
      }

      .site-footer-link:hover {
        color: var(--accent);
      }

      nav.tabs {
        display: inline-flex;
        gap: 0.45rem;
        flex-wrap: wrap;
        width: fit-content;
        max-width: 100%;
        padding: 0.45rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(0, 0, 0, 0.06);
        backdrop-filter: saturate(180%) blur(18px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
      }

      nav.tabs a {
        padding: 0.72rem 1.1rem;
        border-radius: 999px;
        border: 1px solid transparent;
        color: var(--text-subtle);
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        text-decoration: none;
        transition:
          color 160ms ease,
          background-color 160ms ease,
          border-color 160ms ease,
          transform 160ms ease;
      }

      nav.tabs a:hover {
        color: var(--text);
        background: rgba(237, 237, 242, 0.7);
        transform: translateY(-1px);
      }

      nav.tabs a.active {
        color: var(--text);
        background: var(--chip-active);
        border-color: rgba(0, 0, 0, 0.04);
        font-weight: 600;
      }

      .page-hero {
        position: relative;
        overflow: hidden;
        display: grid;
        gap: 1.1rem;
        padding: clamp(2rem, 5vw, 4rem);
        border-radius: var(--radius-panel);
        background:
          radial-gradient(circle at top center, rgba(41, 151, 255, 0.18), transparent 30%),
          linear-gradient(180deg, #ffffff 0%, #f7f7fa 100%);
        border: 1px solid rgba(255, 255, 255, 0.9);
        box-shadow: var(--shadow);
        text-align: center;
      }

      .page-hero::after {
        content: "";
        position: absolute;
        inset: auto auto -28% -12%;
        width: 18rem;
        height: 18rem;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(41, 151, 255, 0.14), transparent 68%);
        pointer-events: none;
      }

      .page-hero--dark {
        background:
          radial-gradient(circle at top center, rgba(41, 151, 255, 0.22), transparent 28%),
          linear-gradient(180deg, #1d1d1f 0%, #272729 100%);
        color: #ffffff;
        border-color: rgba(255, 255, 255, 0.08);
      }

      .page-hero--dark .eyebrow,
      .page-hero--dark .page-summary {
        color: rgba(255, 255, 255, 0.76);
      }

      .eyebrow {
        margin: 0;
        color: var(--accent-link);
        font-size: 0.84rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .page-title {
        margin: 0 auto;
        max-width: 13ch;
        font-size: clamp(2.8rem, 8vw, 4.8rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1.08;
      }

      .page-summary {
        max-width: 44rem;
        margin: 0 auto;
        color: var(--text-muted);
        font-size: 1.0625rem;
        line-height: 1.47;
      }

      .page-actions {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .button-primary,
      .button-secondary,
      .inline-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        min-height: 2.875rem;
        padding: 0.7rem 1.2rem;
        border-radius: 999px;
        font-size: 0.95rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        text-decoration: none;
        transition:
          background-color 160ms ease,
          background-color 160ms ease,
          color 160ms ease,
          transform 160ms ease;
      }

      .button-primary {
        background: var(--accent);
        color: #ffffff;
      }

      .button-primary:hover,
      .button-secondary:hover,
      .inline-link:hover {
        transform: translateY(-1px);
      }

      .button-secondary {
        background: var(--chip-bg);
        color: var(--text);
        border: 1px solid rgba(0, 0, 0, 0.06);
      }

      .inline-link {
        min-height: auto;
        padding: 0;
        color: var(--accent-link);
      }

      .section-card {
        padding: clamp(1.35rem, 2vw, 2rem);
        border-radius: var(--radius-panel);
        background: var(--surface);
        border: 1px solid rgba(255, 255, 255, 0.85);
        box-shadow: var(--shadow);
      }

      .section-card--dark {
        background: linear-gradient(180deg, #1d1d1f 0%, #272729 100%);
        color: #ffffff;
        border-color: rgba(255, 255, 255, 0.08);
      }

      .section-card--dark .section-kicker,
      .section-card--dark .section-meta {
        color: rgba(255, 255, 255, 0.72);
      }

      .section-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
      }

      .section-kicker {
        margin: 0 0 0.35rem;
        color: var(--text-subtle);
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .section-title {
        margin: 0;
        color: var(--text);
        font-size: clamp(1.9rem, 4vw, 2.6rem);
        font-weight: 600;
        letter-spacing: -0.04em;
        line-height: 1.1;
      }

      .section-meta {
        margin: 0;
        color: var(--text-subtle);
        font-size: 0.95rem;
      }

      .empty-state {
        padding: 3rem 1.25rem;
        text-align: center;
        color: var(--text-subtle);
        background: var(--surface-solid);
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
      }

      @media (max-width: 720px) {
        .site-header {
          width: min(100vw - 1rem, 980px);
          border-radius: 26px;
          align-items: start;
          flex-direction: column;
        }

        .site-note {
          display: none;
        }

        .page-title {
          max-width: 100%;
        }

        .section-header {
          align-items: start;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="site-brand" href={homeUrl}>
          <span class="brand-mark">ir</span>
          <span class="brand-lockup">
            <strong>indieReader</strong>
            <span>News and editorial from the indie scene.</span>
          </span>
        </a>
        <p class="site-note">Cards, signings, and movement across independent wrestling.</p>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p class="site-footer-copy">
          indieReader™ ©2026
          <a class="site-footer-link" href="https://www.locopro.pw/">LoCo Pro Wrestling LLC</a>.
          All Rights Reserved.
        </p>
      </footer>
    </div>
  </body>
</html>
