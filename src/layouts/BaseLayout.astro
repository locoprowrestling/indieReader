---
interface Props {
  title?: string;
}

const { title = "indieReader™" } = Astro.props;
const homeUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Daily indie wrestling news and editorial coverage."
    />
    <title>{title} | indieReader™</title>
    <script is:inline>
      (() => {
        const storageKey = "indieReader-theme";
        let theme = "light";

        try {
          const storedTheme = window.localStorage.getItem(storageKey);
          if (storedTheme === "light" || storedTheme === "dark") {
            theme = storedTheme;
          } else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            theme = "dark";
          }
        } catch {
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            theme = "dark";
          }
        }

        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f5f5f7;
        --bg-alt: #fafafc;
        --surface: rgba(255, 255, 255, 0.9);
        --surface-solid: #ffffff;
        --surface-dark: #1d1d1f;
        --surface-dark-2: #272729;
        --border: rgba(0, 0, 0, 0.08);
        --border-strong: rgba(0, 0, 0, 0.12);
        --text: #1d1d1f;
        --text-muted: rgba(0, 0, 0, 0.8);
        --text-subtle: rgba(0, 0, 0, 0.64);
        --accent: #0071e3;
        --accent-link: #0066cc;
        --accent-bright: #2997ff;
        --chip-bg: #fafafc;
        --chip-active: #ededf2;
        --shadow: 0 24px 60px rgba(0, 0, 0, 0.08);
        --shadow-hover: 0 30px 70px rgba(0, 0, 0, 0.12);
        --shadow-soft: 0 16px 36px rgba(0, 0, 0, 0.08);
        --radius-panel: 32px;
        --radius-card: 28px;
        --content-width: min(980px, calc(100vw - 1.5rem));
        --page-radial: rgba(41, 151, 255, 0.12);
        --page-gradient-start: #ffffff;
        --page-gradient-mid: #f5f5f7;
        --page-gradient-end: #fafafc;
        --glass-bg: rgba(255, 255, 255, 0.72);
        --glass-bg-soft: rgba(255, 255, 255, 0.68);
        --glass-border: rgba(0, 0, 0, 0.06);
        --tab-bg: rgba(255, 255, 255, 0.7);
        --tab-hover-bg: rgba(237, 237, 242, 0.7);
        --hero-radial: rgba(41, 151, 255, 0.18);
        --hero-start: #ffffff;
        --hero-end: #f7f7fa;
        --hero-border: rgba(255, 255, 255, 0.9);
        --hero-orb: rgba(41, 151, 255, 0.14);
        --panel-gradient-start: rgba(255, 255, 255, 0.95);
        --panel-gradient-end: rgba(247, 247, 250, 0.92);
        --panel-border: rgba(255, 255, 255, 0.88);
        --accent-soft: rgba(0, 113, 227, 0.18);
        --toggle-bg: rgba(250, 250, 252, 0.84);
        --toggle-hover-bg: rgba(237, 237, 242, 0.88);
        --toggle-border: rgba(0, 0, 0, 0.08);
        --toggle-icon-bg: rgba(0, 113, 227, 0.12);
      }

      :root[data-theme="dark"] {
        color-scheme: dark;
        --bg: #0f1622;
        --bg-alt: #151d2b;
        --surface: rgba(19, 27, 40, 0.9);
        --surface-solid: #141b28;
        --surface-dark: #090d14;
        --surface-dark-2: #1b2535;
        --border: rgba(255, 255, 255, 0.08);
        --border-strong: rgba(255, 255, 255, 0.12);
        --text: #eff3fa;
        --text-muted: rgba(255, 255, 255, 0.82);
        --text-subtle: rgba(255, 255, 255, 0.58);
        --accent: #4aa8ff;
        --accent-link: #7fc2ff;
        --accent-bright: #b7deff;
        --chip-bg: rgba(255, 255, 255, 0.07);
        --chip-active: rgba(255, 255, 255, 0.11);
        --shadow: 0 28px 70px rgba(0, 0, 0, 0.42);
        --shadow-hover: 0 36px 80px rgba(0, 0, 0, 0.5);
        --shadow-soft: 0 18px 40px rgba(0, 0, 0, 0.32);
        --page-radial: rgba(74, 168, 255, 0.18);
        --page-gradient-start: #060b12;
        --page-gradient-mid: #0c131e;
        --page-gradient-end: #141c29;
        --glass-bg: rgba(12, 18, 28, 0.74);
        --glass-bg-soft: rgba(12, 18, 28, 0.7);
        --glass-border: rgba(255, 255, 255, 0.08);
        --tab-bg: rgba(10, 15, 23, 0.72);
        --tab-hover-bg: rgba(255, 255, 255, 0.06);
        --hero-radial: rgba(74, 168, 255, 0.22);
        --hero-start: #121a28;
        --hero-end: #181f2f;
        --hero-border: rgba(255, 255, 255, 0.08);
        --hero-orb: rgba(74, 168, 255, 0.18);
        --panel-gradient-start: rgba(24, 32, 47, 0.96);
        --panel-gradient-end: rgba(18, 24, 36, 0.92);
        --panel-border: rgba(255, 255, 255, 0.08);
        --accent-soft: rgba(127, 194, 255, 0.18);
        --toggle-bg: rgba(255, 255, 255, 0.06);
        --toggle-hover-bg: rgba(255, 255, 255, 0.1);
        --toggle-border: rgba(255, 255, 255, 0.08);
        --toggle-icon-bg: rgba(127, 194, 255, 0.12);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
      }

      body {
        font-family:
          -apple-system,
          BlinkMacSystemFont,
          "SF Pro Display",
          "SF Pro Text",
          "Helvetica Neue",
          Arial,
          sans-serif;
        background:
          radial-gradient(circle at top center, var(--page-radial), transparent 28%),
          linear-gradient(
            180deg,
            var(--page-gradient-start) 0%,
            var(--page-gradient-mid) 26%,
            var(--page-gradient-end) 100%
          );
        color: var(--text);
        line-height: 1.47;
      }

      a {
        color: inherit;
      }

      .site-shell {
        padding: 0.9rem 0 4rem;
      }

      .skip-link {
        position: absolute;
        top: 0.75rem;
        left: 50%;
        transform: translate(-50%, -160%);
        padding: 0.72rem 1rem;
        border-radius: 999px;
        background: var(--surface-dark);
        color: #ffffff;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        box-shadow: var(--shadow-soft);
        z-index: 100;
        transition: transform 160ms ease;
      }

      .skip-link:focus,
      .skip-link:focus-visible {
        transform: translate(-50%, 0);
      }

      .site-header {
        width: var(--content-width);
        margin: 0 auto 1.5rem;
        padding: 0.65rem 0.85rem;
        border: 1px solid var(--glass-border);
        border-radius: 999px;
        background: var(--glass-bg);
        box-shadow: 0 8px 26px rgba(0, 0, 0, 0.08);
        backdrop-filter: saturate(180%) blur(24px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        position: sticky;
        top: 0.75rem;
        z-index: 20;
      }

      .site-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        text-decoration: none;
      }

      .brand-mark {
        width: 2rem;
        height: 2rem;
        border-radius: 50%;
        display: grid;
        place-items: center;
        background: linear-gradient(180deg, #1d1d1f, #2a2a2d);
        color: #ffffff;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: -0.04em;
      }

      .brand-lockup {
        display: grid;
        gap: 0.05rem;
      }

      .brand-lockup strong {
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: -0.02em;
      }

      .brand-lockup span {
        font-size: 0.78rem;
        color: var(--text-subtle);
      }

      .site-note {
        margin: 0;
        color: var(--text-subtle);
        font-size: 0.82rem;
      }

      .site-header-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-left: auto;
      }

      .theme-toggle {
        appearance: none;
        border: 1px solid var(--toggle-border);
        background: var(--toggle-bg);
        color: var(--text);
        min-height: 2.5rem;
        min-width: 2.5rem;
        padding: 0.36rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font: inherit;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        cursor: pointer;
        transition:
          background-color 160ms ease,
          border-color 160ms ease,
          transform 160ms ease,
          color 160ms ease;
      }

      .theme-toggle:hover {
        background: var(--toggle-hover-bg);
        transform: translateY(-1px);
      }

      .theme-toggle-icon {
        width: 1.6rem;
        height: 1.6rem;
        border-radius: 999px;
        display: grid;
        place-items: center;
        background: var(--toggle-icon-bg);
        color: var(--accent-link);
        font-size: 0.82rem;
        line-height: 1;
      }

      main {
        width: var(--content-width);
        margin: 0 auto;
        display: grid;
        gap: 1.4rem;
      }

      .site-footer {
        width: var(--content-width);
        margin: 1.5rem auto 0;
        padding: 1rem 1.25rem;
        border-radius: 24px;
        background: var(--glass-bg-soft);
        border: 1px solid var(--glass-border);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
        backdrop-filter: saturate(180%) blur(18px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.9rem;
        flex-wrap: wrap;
      }

      .site-footer-copy {
        margin: 0;
        color: var(--text-subtle);
        font-size: 0.82rem;
        line-height: 1.5;
      }

      .site-footer-link {
        color: var(--accent-link);
        font-weight: 600;
        text-decoration: none;
      }

      .site-footer-link:hover {
        color: var(--accent);
      }

      nav.tabs {
        display: inline-flex;
        gap: 0.45rem;
        flex-wrap: wrap;
        width: fit-content;
        max-width: 100%;
        padding: 0.45rem;
        border-radius: 999px;
        background: var(--tab-bg);
        border: 1px solid var(--glass-border);
        backdrop-filter: saturate(180%) blur(18px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
      }

      nav.tabs a {
        padding: 0.72rem 1.1rem;
        border-radius: 999px;
        border: 1px solid transparent;
        color: var(--text-subtle);
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        text-decoration: none;
        transition:
          color 160ms ease,
          background-color 160ms ease,
          border-color 160ms ease,
          transform 160ms ease;
      }

      nav.tabs a:hover {
        color: var(--text);
        background: var(--tab-hover-bg);
        transform: translateY(-1px);
      }

      nav.tabs a.active {
        color: var(--text);
        background: var(--chip-active);
        border-color: rgba(0, 0, 0, 0.04);
        font-weight: 600;
      }

      .page-hero {
        position: relative;
        overflow: hidden;
        display: grid;
        gap: 1.1rem;
        padding: clamp(2rem, 5vw, 4rem);
        border-radius: var(--radius-panel);
        background:
          radial-gradient(circle at top center, var(--hero-radial), transparent 30%),
          linear-gradient(180deg, var(--hero-start) 0%, var(--hero-end) 100%);
        border: 1px solid var(--hero-border);
        box-shadow: var(--shadow);
        text-align: center;
      }

      .page-hero::after {
        content: "";
        position: absolute;
        inset: auto auto -28% -12%;
        width: 18rem;
        height: 18rem;
        border-radius: 50%;
        background: radial-gradient(circle, var(--hero-orb), transparent 68%);
        pointer-events: none;
      }

      .page-hero--dark {
        background:
          radial-gradient(circle at top center, rgba(41, 151, 255, 0.22), transparent 28%),
          linear-gradient(180deg, #1d1d1f 0%, #272729 100%);
        color: #ffffff;
        border-color: rgba(255, 255, 255, 0.08);
      }

      .page-hero--dark .eyebrow,
      .page-hero--dark .page-summary {
        color: rgba(255, 255, 255, 0.76);
      }

      .eyebrow {
        margin: 0;
        color: var(--accent-link);
        font-size: 0.84rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .page-title {
        margin: 0 auto;
        max-width: 13ch;
        font-size: clamp(2.8rem, 8vw, 4.8rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1.08;
      }

      .page-summary {
        max-width: 44rem;
        margin: 0 auto;
        color: var(--text-muted);
        font-size: 1.0625rem;
        line-height: 1.47;
      }

      .page-actions {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .button-primary,
      .button-secondary,
      .inline-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        min-height: 2.875rem;
        padding: 0.7rem 1.2rem;
        border-radius: 999px;
        font-size: 0.95rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        text-decoration: none;
        transition:
          background-color 160ms ease,
          background-color 160ms ease,
          color 160ms ease,
          transform 160ms ease;
      }

      .button-primary {
        background: var(--accent);
        color: #ffffff;
      }

      .button-primary:hover,
      .button-secondary:hover,
      .inline-link:hover {
        transform: translateY(-1px);
      }

      .button-secondary {
        background: var(--chip-bg);
        color: var(--text);
        border: 1px solid var(--glass-border);
      }

      .inline-link {
        min-height: auto;
        padding: 0;
        color: var(--accent-link);
      }

      .section-card {
        padding: clamp(1.35rem, 2vw, 2rem);
        border-radius: var(--radius-panel);
        background: var(--surface);
        border: 1px solid var(--panel-border);
        box-shadow: var(--shadow);
      }

      .section-card--dark {
        background: linear-gradient(180deg, #1d1d1f 0%, #272729 100%);
        color: #ffffff;
        border-color: rgba(255, 255, 255, 0.08);
      }

      .section-card--dark .section-kicker,
      .section-card--dark .section-meta {
        color: rgba(255, 255, 255, 0.72);
      }

      .section-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
      }

      .section-kicker {
        margin: 0 0 0.35rem;
        color: var(--text-subtle);
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .section-title {
        margin: 0;
        color: var(--text);
        font-size: clamp(1.9rem, 4vw, 2.6rem);
        font-weight: 600;
        letter-spacing: -0.04em;
        line-height: 1.1;
      }

      .section-meta {
        margin: 0;
        color: var(--text-subtle);
        font-size: 0.95rem;
      }

      .empty-state {
        padding: 3rem 1.25rem;
        text-align: center;
        color: var(--text-subtle);
        background: var(--surface-solid);
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
      }

      @media (max-width: 720px) {
        .site-header {
          width: min(100vw - 1rem, 980px);
          border-radius: 26px;
          align-items: start;
          flex-direction: column;
        }

        .site-header-actions {
          width: 100%;
          justify-content: flex-end;
        }

        .site-note {
          display: none;
        }

        .page-title {
          max-width: 100%;
        }

        .section-header {
          align-items: start;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <a class="skip-link" href="#main-content">Skip to content</a>
      <header class="site-header">
        <a class="site-brand" href={homeUrl}>
          <span class="brand-mark">ir</span>
          <span class="brand-lockup">
            <strong>indieReader™</strong>
            <span>News and editorial from the indie scene.</span>
          </span>
        </a>
        <div class="site-header-actions">
          <p class="site-note">Cards, signings, and movement across independent wrestling.</p>
          <button
            class="theme-toggle"
            type="button"
            data-theme-toggle
            aria-pressed="false"
            aria-label="Switch to dark mode"
            title="Switch to dark mode"
          >
            <span class="theme-toggle-icon" data-theme-icon aria-hidden="true">☀</span>
          </button>
        </div>
      </header>
      <main id="main-content">
        <slot />
      </main>
      <footer class="site-footer">
        <p class="site-footer-copy">
          indieReader™ ©2026
          <a class="site-footer-link" href="https://www.locopro.pw/">LoCo Pro Wrestling LLC</a>.
          All Rights Reserved.
        </p>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const storageKey = "indieReader-theme";
        const root = document.documentElement;
        const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

        const getStoredTheme = () => {
          try {
            const storedTheme = window.localStorage.getItem(storageKey);
            return storedTheme === "light" || storedTheme === "dark" ? storedTheme : null;
          } catch {
            return null;
          }
        };

        const getPreferredTheme = () => {
          const storedTheme = getStoredTheme();
          if (storedTheme) {
            return storedTheme;
          }

          return mediaQuery.matches ? "dark" : "light";
        };

        const applyTheme = (theme) => {
          root.dataset.theme = theme;
          root.style.colorScheme = theme;

          document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
            const nextTheme = theme === "dark" ? "light" : "dark";
            const themeIcon = theme === "dark" ? "☾" : "☀";
            const buttonLabel = `Switch to ${nextTheme} mode`;

            button.setAttribute("aria-pressed", String(theme === "dark"));
            button.setAttribute("aria-label", buttonLabel);
            button.setAttribute("title", buttonLabel);

            const icon = button.querySelector("[data-theme-icon]");
            if (icon) {
              icon.textContent = themeIcon;
            }
          });
        };

        const bindThemeToggle = () => {
          document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
            if (button.dataset.bound === "true") {
              return;
            }

            button.dataset.bound = "true";
            button.addEventListener("click", () => {
              const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";

              try {
                window.localStorage.setItem(storageKey, nextTheme);
              } catch {
                // Ignore storage failures and still update the live theme.
              }

              applyTheme(nextTheme);
            });
          });
        };

        const handlePreferenceChange = (event) => {
          if (!getStoredTheme()) {
            applyTheme(event.matches ? "dark" : "light");
          }
        };

        applyTheme(getPreferredTheme());
        bindThemeToggle();

        if (typeof mediaQuery.addEventListener === "function") {
          mediaQuery.addEventListener("change", handlePreferenceChange);
        } else if (typeof mediaQuery.addListener === "function") {
          mediaQuery.addListener(handlePreferenceChange);
        }
      })();
    </script>
  </body>
</html>
