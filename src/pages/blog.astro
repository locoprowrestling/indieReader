---
import { getCollection, render } from "astro:content";
import BlogPost from "../components/BlogPost.astro";
import Tabs from "../components/Tabs.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = await getCollection("posts");
posts.sort((a, b) => {
  const dateDiff = b.data.date.getTime() - a.data.date.getTime();
  if (dateDiff !== 0) {
    return dateDiff;
  }

  return a.data.time < b.data.time ? 1 : -1;
});

const latest = posts[0];
const rendered = latest ? await render(latest) : null;
---

<BaseLayout title="Blog Post">
  <Tabs active="blog" />
  <section class="page-hero page-hero--dark">
    <p class="eyebrow">Latest column</p>
    <h2 class="page-title">{latest ? latest.data.title : "Editorial from the indie scene"}</h2>
    <p class="page-summary">
      {latest?.data.type === "colorado"
        ? "A special Friday edition covering the Colorado indie wrestling scene."
        : "Twice-daily editorial perspective on the stories shaping the indie scene."}
    </p>
  </section>
  {
    latest && rendered ? (
      <BlogPost title={latest.data.title} date={latest.data.date} time={latest.data.time} type={latest.data.type} story_count={latest.data.story_count}>
        <rendered.Content />
      </BlogPost>
    ) : (
      <p class="empty-state">No blog posts have been generated yet.</p>
    )
  }
</BaseLayout>
