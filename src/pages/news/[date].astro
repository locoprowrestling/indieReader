---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsFeed from "../../components/NewsFeed.astro";
import Tabs from "../../components/Tabs.astro";
import { withBase } from "../../lib/base";
import { NEWS_BEGINNING_PATH, getNewsNavigation, listNewsDates, loadStoriesForDate } from "../../lib/news";

export function getStaticPaths() {
  return listNewsDates().map((date) => ({ params: { date } }));
}

const { date } = Astro.params;
const stories = loadStoriesForDate(date);
const newsNav = getNewsNavigation(date);
const previousHref = newsNav.olderDate
  ? withBase(`/news/${newsNav.olderDate}/`)
  : withBase(NEWS_BEGINNING_PATH);
const nextHref = newsNav.newerDate ? withBase(`/news/${newsNav.newerDate}/`) : null;
---

<BaseLayout title={`News - ${date}`}>
  <Tabs active="news" />
  <section class="page-hero">
    <p class="eyebrow">Daily file</p>
    <h2 class="page-title">
      {new Date(`${date}T12:00:00Z`).toLocaleDateString("en-US", {
        weekday: "long",
        month: "long",
        day: "numeric",
        year: "numeric",
      })}
    </h2>
    <p class="page-summary">
      A date-specific look at the stories collected for this edition of indieReader™.
    </p>
    <div class="page-actions">
      <a class="button-secondary" href={previousHref}>Previous</a>
      {nextHref ? <a class="button-secondary" href={nextHref}>Next</a> : null}
      {!newsNav.isLatest ? <a class="button-primary" href={withBase("/")}>Today</a> : null}
    </div>
  </section>
  <section class="section-card">
    <div class="section-header">
      <div>
        <p class="section-kicker">Collected stories</p>
        <h3 class="section-title">{stories.length} item{stories.length === 1 ? "" : "s"}</h3>
      </div>
    </div>
    <NewsFeed stories={stories} />
  </section>
</BaseLayout>
