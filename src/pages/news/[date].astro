---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsFeed from "../../components/NewsFeed.astro";
import Tabs from "../../components/Tabs.astro";
import { withBase } from "../../lib/base";
import { listNewsDates, loadStoriesForDate } from "../../lib/news";

export function getStaticPaths() {
  return listNewsDates().map((date) => ({ params: { date } }));
}

const { date } = Astro.params;
const stories = loadStoriesForDate(date);
const today = new Date().toISOString().slice(0, 10);
const prev = new Date(new Date(`${date}T12:00:00Z`).getTime() - 86_400_000)
  .toISOString()
  .slice(0, 10);
const next = new Date(new Date(`${date}T12:00:00Z`).getTime() + 86_400_000)
  .toISOString()
  .slice(0, 10);
---

<BaseLayout title={`News - ${date}`}>
  <Tabs active="news" />
  <section class="page-hero">
    <p class="eyebrow">Daily file</p>
    <h2 class="page-title">
      {new Date(`${date}T12:00:00Z`).toLocaleDateString("en-US", {
        weekday: "long",
        month: "long",
        day: "numeric",
        year: "numeric",
      })}
    </h2>
    <p class="page-summary">
      A date-specific look at the stories collected for this edition of indieReader.
    </p>
    <div class="page-actions">
      <a class="button-secondary" href={withBase(`/news/${prev}/`)}>Previous</a>
      {date !== today ? <a class="button-secondary" href={withBase(`/news/${next}/`)}>Next</a> : null}
      {date !== today ? <a class="button-primary" href={withBase("/")}>Today</a> : null}
    </div>
  </section>
  <section class="section-card">
    <div class="section-header">
      <div>
        <p class="section-kicker">Collected stories</p>
        <h3 class="section-title">{stories.length} item{stories.length === 1 ? "" : "s"}</h3>
      </div>
    </div>
    <NewsFeed stories={stories} />
  </section>
</BaseLayout>
