---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsFeed from "../components/NewsFeed.astro";
import Tabs from "../components/Tabs.astro";
import { loadLatestStories } from "../lib/news";

const stories = loadLatestStories();
const todayLabel = new Date().toLocaleDateString("en-US", {
  weekday: "long",
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: "America/Denver",
});

const yesterday = new Date(Date.now() - 86_400_000).toISOString().slice(0, 10);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="News">
  <Tabs active="news" />
  <h2 class="section-title">{todayLabel}</h2>
  <NewsFeed stories={stories} />
  <p style="margin: 1.5rem 0 0; text-align: center;">
    <a
      href={`${base}news/${yesterday}/`}
      style="color: var(--muted); font-size: 0.9rem; text-decoration: none;"
    >
      View yesterday's news
    </a>
  </p>
</BaseLayout>
